/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    conf/base.config
    Default resource allocation for phylogeoflow processes.

    This file defines ONLY how much CPU / memory / time each class of process
    receives, plus retry-on-resource-exhaustion behaviour. It contains no params,
    no manifest, and no profiles — those live in nextflow.config, which includes
    this file.

    Resources scale with `task.attempt`, so a process that dies from too little
    memory/time is automatically retried with more (up to the max_* ceilings and
    maxRetries). Override any of this per-site with a `-c custom.config`.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // ---- global defaults (every process, unless overridden below) ----
    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { check_max( 6.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    // retry once or twice on out-of-memory / walltime / API-401 style failures,
    // otherwise stop the offending task.
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 401) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // ---- resource classes (attach with `label 'process_xxx'` in a module) ----
    withLabel:process_single {
        cpus   = { check_max( 1                   , 'cpus'   ) }
        memory = { check_max( 4.GB  * task.attempt , 'memory' ) }
        time   = { check_max( 4.h   * task.attempt , 'time'   ) }
    }
    withLabel:process_low {
        cpus   = { check_max( 2     * task.attempt , 'cpus'   ) }
        memory = { check_max( 8.GB  * task.attempt , 'memory' ) }
        time   = { check_max( 4.h   * task.attempt , 'time'   ) }
    }
    withLabel:process_medium {
        cpus   = { check_max( 6     * task.attempt , 'cpus'   ) }
        memory = { check_max( 36.GB * task.attempt , 'memory' ) }
        time   = { check_max( 8.h   * task.attempt , 'time'   ) }
    }
    withLabel:process_high {
        cpus   = { check_max( 12    * task.attempt , 'cpus'   ) }
        memory = { check_max( 72.GB * task.attempt , 'memory' ) }
        time   = { check_max( 16.h  * task.attempt , 'time'   ) }
    }
    withLabel:process_long {
        time   = { check_max( 48.h  * task.attempt , 'time'   ) }
    }
    withLabel:process_high_memory {
        memory = { check_max( 120.GB * task.attempt, 'memory' ) }
    }

    // ---- per-process overrides (by process NAME) ----
    // Retrieval steps are I/O- and API-bound, not CPU-bound: keep them single-core
    // but give them long walltime (async GBIF downloads, large BOLD fetches) and be
    // gentle on API rate limits by limiting parallelism.
    withName:'FETCH_GBIF' {
        cpus   = 1
        time   = { check_max( 12.h * task.attempt, 'time' ) }   // occ_download can queue for hours
        maxForks = 1
    }
    withName:'FETCH_BOLD' {
        cpus   = 1
        time   = { check_max( 8.h  * task.attempt, 'time' ) }
        maxForks = 2                                            // respect BOLD rate limits
    }
    withName:'FETCH_GENBANK_EDIRECT|FETCH_GENBANK_RENTREZ' {
        cpus   = 1
        time   = { check_max( 6.h  * task.attempt, 'time' ) }
        maxForks = 1                                            // NCBI: <=3-10 req/s total
    }

    // Alignment / phylogenetics are the compute-heavy stages (wire as you build them):
    withName:'ALIGN_.*|IQTREE.*|RAXML.*' {
        label  = 'process_high'
    }
}
