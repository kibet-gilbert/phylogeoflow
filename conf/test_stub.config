/*
    conf/test_stub.config
    Minimal inputs for `-profile test_stub -stub`. Runs every process's stub:
    block so the whole DAG can be exercised with no network/API access.

    Usage:
        nextflow run . -profile test_stub,docker -stub
*/

params {
    config_profile_name        = 'Stub test profile'
    config_profile_description  = 'No-network dry run using process stubs'

    target_taxon   = 'Ceratitis'
    taxon_rank     = 'genus'
    databases      = 'bold,genbank,gbif'
    genbank_engine = 'both'
    markers        = ['COI-5P']
    geography      = ['Kenya', 'Uganda']
    country_codes  = ['KE', 'UG']
    min_seq_len    = 500

    outdir         = 'results_stub'

    max_cpus       = 2
    max_memory     = '4.GB'
    max_time       = '1.h'
}
