/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    conf/modules.config
    Per-process configuration for phylogeoflow.

    This file holds, for each process:
        ext.args     — command-line flags passed to the underlying tool
        ext.args2    — a second flag set where a process runs two tools
        ext.prefix   — output file basename
        publishDir   — where that process's results are copied under --outdir

    It complements conf/base.config (which sets CPU/memory/time). Resources there,
    tool arguments here. Nothing in this file changes what a process DOES — only
    how its tool is invoked and where its output lands.

    Processes are grouped by pipeline stage (Part 1.1 → 2.9). Entries for stages
    marked PLANNED are inert scaffolding: the withName selector matches nothing
    until that process exists, then activates automatically. Selectors use the
    process NAME (optionally within a subworkflow path via ':' separators).

    Most ext.args below are DERIVED FROM PARAMS so the schema stays the single
    source of truth: e.g. IQ-TREE's model flag reads params.substitution_model.
    Adjust defaults here; expose user-facing knobs in nextflow_schema.json.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // ============================================================
    //  Part 1.1 — Data retrieval  (IMPLEMENTED)
    // ============================================================
    // Fetchers take their query from params via the module script itself,
    // so ext.args here is for any EXTRA raw flags a power user wants to append.

    withName: 'FETCH_BOLD' {
        ext.args   = ''                       // extra flags appended to fetch_bold.R
        publishDir = [
            path: { "${params.outdir}/retrieval/bold" },
            mode: params.publish_dir_mode,
            pattern: "out/*"
        ]
    }

    withName: 'FETCH_GBIF' {
        ext.args   = ''                       // extra flags appended to fetch_gbif.R
        publishDir = [
            path: { "${params.outdir}/retrieval/gbif" },
            mode: params.publish_dir_mode,
            pattern: "out/*"
        ]
    }

    withName: 'FETCH_GENBANK_EDIRECT|FETCH_GENBANK_RENTREZ' {
        ext.args   = ''                       // extra flags appended to the fetcher
        publishDir = [
            path: { "${params.outdir}/retrieval/genbank/${task.process.tokenize(':').last().contains('RENTREZ') ? 'rentrez' : 'edirect'}" },
            mode: params.publish_dir_mode,
            pattern: "out/*"
        ]
    }

    // ============================================================
    //  Part 1.2 — Curation & harmonisation  (cleaners IMPLEMENTED; harmonize SCAFFOLDED)
    // ============================================================

    withName: 'CLEAN_BOLD' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/curation/bold" },
            mode: params.publish_dir_mode,
            pattern: "clean/*"
        ]
    }

    withName: 'CLEAN_GBIF' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/curation/gbif" },
            mode: params.publish_dir_mode,
            pattern: "clean/*"
        ]
    }

    withName: 'CLEAN_GENBANK' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/curation/genbank/${engine}" },
            mode: params.publish_dir_mode,
            pattern: "clean/*"
        ]
    }

    // PLANNED: cross-database merge/dedup
    withName: 'HARMONIZE' {
        ext.args   = { "--prefer ${params.harmonize_prefer}" }
        ext.prefix = { "${meta.id}.pooled" }
        publishDir = [
            path: { "${params.outdir}/curation/harmonized" },
            mode: params.publish_dir_mode
        ]
    }

    // PLANNED: engine comparison report (GenBank edirect vs rentrez)
    withName: 'COMPARE_ENGINES' {
        publishDir = [
            path: { "${params.outdir}/curation/genbank/comparison" },
            mode: params.publish_dir_mode
        ]
    }

    // PLANNED: RDPClassifier taxonomic (re)assignment
    withName: 'RDP_CLASSIFY' {
        ext.args   = { [
            "--conf ${params.classifier_min_bootstrap}",
            "--train_set ${params.classifier_trainset}"
        ].join(' ') }
        ext.prefix = { "${meta.id}.rdp" }
        publishDir = [
            path: { "${params.outdir}/curation/classification" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 1.3 — Alignment & trimming  (PLANNED)
    // ============================================================

    // MAFFT (default aligner)
    withName: 'ALIGN_MAFFT' {
        ext.args   = '--auto --adjustdirection'      // robust default; --localpair for accuracy
        ext.prefix = { "${meta.id}.${meta.marker ?: 'aln'}.mafft" }
        publishDir = [
            path: { "${params.outdir}/alignment/mafft" },
            mode: params.publish_dir_mode
        ]
    }

    // PASTA (scalable, very large sets)
    withName: 'ALIGN_PASTA' {
        ext.args   = '--aligner mafft --merger muscle'
        ext.prefix = { "${meta.id}.${meta.marker ?: 'aln'}.pasta" }
        publishDir = [
            path: { "${params.outdir}/alignment/pasta" },
            mode: params.publish_dir_mode
        ]
    }

    // T-Coffee (regressive mode for large datasets)
    withName: 'ALIGN_TCOFFEE' {
        ext.args   = '-reg -reg_nseq 100 -reg_tree mbed -reg_method mafftginsi_msa'
        ext.prefix = { "${meta.id}.${meta.marker ?: 'aln'}.tcoffee" }
        publishDir = [
            path: { "${params.outdir}/alignment/tcoffee" },
            mode: params.publish_dir_mode
        ]
    }

    // T-Coffee CORE/TCS alignment reliability scoring
    withName: 'TCS_EVAL' {
        ext.args   = '-evaluate -output score_ascii,html'
        ext.prefix = { "${meta.id}.tcs" }
        publishDir = [
            path: { "${params.outdir}/alignment/tcs_eval" },
            mode: params.publish_dir_mode
        ]
    }

    // BMGE trimming (entropy + gap thresholds from params)
    withName: 'TRIM_BMGE' {
        ext.args   = { "-t DNA -h ${params.bmge_entropy} -g 0.95" }
        ext.prefix = { "${meta.id}.${meta.marker ?: 'aln'}.bmge" }
        publishDir = [
            path: { "${params.outdir}/alignment/trimmed" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 1.4 — Phylogenetic inference  (PLANNED)
    // ============================================================

    // IQ-TREE (default). Model: ModelFinder unless a fixed model is given.
    withName: 'IQTREE' {
        ext.args   = {
            def m = (params.model_selection == 'fixed' && params.substitution_model)
                        ? "-m ${params.substitution_model}"
                        : "-m MFP"                         // ModelFinder Plus
            def og = params.outgroups ? "-o ${ (params.outgroups instanceof List ? params.outgroups.join(',') : params.outgroups) }" : ''
            [ m, "-B ${params.bootstrap}", "-bnni", og, "--seqtype DNA" ].findAll{ it }.join(' ')
        }
        ext.prefix = { "${meta.id}.iqtree" }
        publishDir = [
            path: { "${params.outdir}/phylogenetics/iqtree" },
            mode: params.publish_dir_mode
        ]
    }

    // RAxML-NG (alternative ML engine)
    withName: 'RAXML_NG' {
        ext.args   = {
            def m  = params.substitution_model ?: 'GTR+G'
            def bs = params.bootstrap
            "--all --model ${m} --bs-trees ${bs} --seed 42"
        }
        ext.prefix = { "${meta.id}.raxmlng" }
        publishDir = [
            path: { "${params.outdir}/phylogenetics/raxml-ng" },
            mode: params.publish_dir_mode
        ]
    }

    // FastTree (fast exploratory)
    withName: 'FASTTREE' {
        ext.args   = '-gtr -nt -gamma'
        ext.prefix = { "${meta.id}.fasttree" }
        publishDir = [
            path: { "${params.outdir}/phylogenetics/fasttree" },
            mode: params.publish_dir_mode
        ]
    }

    // Standalone model selection (when not using IQ-TREE's built-in MFP)
    withName: 'MODELTEST_NG' {
        ext.args   = '-d nt -T raxml'
        ext.prefix = { "${meta.id}.modeltest" }
        publishDir = [
            path: { "${params.outdir}/phylogenetics/modeltest" },
            mode: params.publish_dir_mode
        ]
    }

    // EPA-NG phylogenetic placement of query sequences
    withName: 'EPANG' {
        ext.args   = '--heuristic-exponent 0.5'
        ext.prefix = { "${meta.id}.epang" }
        publishDir = [
            path: { "${params.outdir}/phylogenetics/placement" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 1.5 — Species delimitation  (PLANNED)
    // ============================================================

    withName: 'MPTP' {
        ext.args   = { "--multi --mcmc ${params.mptp_mcmc} --mcmc_sample 1000 --mcmc_burnin 100000" }
        ext.prefix = { "${meta.id}.mptp" }
        publishDir = [
            path: { "${params.outdir}/delimitation/mptp" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'ASAP' {
        ext.args   = '-d 0'                          // Kimura K80 by default
        ext.prefix = { "${meta.id}.asap" }
        publishDir = [
            path: { "${params.outdir}/delimitation/asap" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 1.6 — Population structure & phylogeography  (PLANNED)
    // ============================================================

    withName: 'HAPLONET' {
        ext.args   = { "--type ${params.diff_stat}" }
        ext.prefix = { "${meta.id}.haplonet" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/haplotype_networks" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'DIFFERENTIATION' {
        ext.args   = { "--stat ${params.diff_stat} --permutations ${params.permutations}" }
        ext.prefix = { "${meta.id}.diff" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/differentiation" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'AMOVA' {
        ext.args   = { "--permutations ${params.permutations}" }
        ext.prefix = { "${meta.id}.amova" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/amova" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SPATIAL_CLUSTER' {
        ext.args   = { "--method ${params.cluster_method}" }
        ext.prefix = { "${meta.id}.${params.cluster_method}" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/clustering" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'NEUTRALITY' {
        ext.args   = ''                              // Tajima's D, Fu's Fs, mismatch
        ext.prefix = { "${meta.id}.neutrality" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/neutrality" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'BASTA' {
        ext.args   = ''                              // BEAST2 XML config-driven
        ext.prefix = { "${meta.id}.basta" }
        publishDir = [
            path: { "${params.outdir}/phylogeography/basta" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 2.7 — Environmental data retrieval  (SCAFFOLDED/PLANNED)
    // ============================================================

    withName: 'FETCH_ENVIRONMENTAL' {
        ext.args   = {
            [ "--layers ${params.env_layers}",
              "--bioclim_source ${params.bioclim_source}",
              "--resolution ${params.env_resolution}",
              (params.future_climate ? "--future" : "") ].findAll{ it }.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/environmental/rasters" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'EXTRACT_ENV' {
        ext.args   = ''                              // extract raster values at occurrence points
        ext.prefix = { "${meta.id}.env_at_points" }
        publishDir = [
            path: { "${params.outdir}/environmental/extracted" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 2.8 — Niche / distribution modelling  (PLANNED)
    // ============================================================

    withName: 'SDM' {
        ext.args   = {
            [ "--algorithm ${params.sdm_algorithm}",
              "--reduction ${params.predictor_reduction}",
              "--background ${params.background_points}",
              (params.future_climate ? "--project_future" : "") ].findAll{ it }.join(' ')
        }
        ext.prefix = { "${meta.id}.sdm.${params.sdm_algorithm}" }
        publishDir = [
            path: { "${params.outdir}/sdm" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Part 2.9 — Landscape genetics (IBD vs IBE)  (PLANNED)
    // ============================================================

    withName: 'LANDSCAPE_GENETICS' {
        ext.args   = {
            [ "--method ${params.lg_method}",
              "--permutations ${params.lg_permutations}" ].join(' ')
        }
        ext.prefix = { "${meta.id}.landgen.${params.lg_method}" }
        publishDir = [
            path: { "${params.outdir}/landscape_genetics" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  Utility  (IMPLEMENTED)
    // ============================================================

    // Collated software versions — publish to pipeline_info, not a stage dir.
    withName: 'softwareVersionsToYAML|CUSTOM_DUMPSOFTWAREVERSIONS' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            pattern: '*_versions.yml'
        ]
    }
}
