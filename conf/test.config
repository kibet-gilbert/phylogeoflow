/*
    conf/test.config
    Small but REAL run (hits live APIs). Kept tiny: one small genus, one marker,
    one country, GenBank via edirect only. For a true no-network check use
    -profile test_stub with -stub instead.

    Usage:
        nextflow run . -profile test,docker
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description  = 'Minimal live-API test dataset'

    target_taxon   = 'Ceratitis'
    taxon_rank     = 'genus'
    databases      = 'genbank'          // smallest, no key required for public efetch
    genbank_engine = 'edirect'
    markers        = ['COI-5P']
    geography      = ['Kenya']
    min_seq_len    = 500
    genbank_batch  = 50

    outdir         = 'results_test'

    max_cpus       = 2
    max_memory     = '6.GB'
    max_time       = '2.h'
}
