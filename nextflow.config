/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nextflow.config — phylogeoflow
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    // ================= Core query =================
    target_taxon        = null
    taxon_rank          = 'genus'
    run_id              = null
    outdir              = 'results'

    // ============ Part 1.1 — Data retrieval ============
    databases           = 'bold,genbank,gbif'   // comma subset: bold,genbank,gbif
    genbank_engine      = 'edirect'             // edirect | rentrez | both
    markers             = ['COI-5P']            // list or comma string
    geography           = null                  // country names (BOLD/GenBank)
    country_codes       = null                  // ISO2 codes (GBIF)
    min_seq_len         = 500
    max_seq_len         = null
    min_year            = null
    genbank_batch       = 200
    bold_batch          = 5000
    entrez_key          = null                  // optional; secret preferred

    // ======== Part 1.2 — Curation & harmonisation ========
    max_coord_err            = null             // metres
    harmonize_prefer         = 'bold'           // bold | genbank
    run_classification       = true
    classifier_trainset      = 'CO1v4.0'
    classifier_min_bootstrap = 1.0

    // ========= Part 1.3 — Alignment & trimming =========
    aligner             = 'mafft'               // mafft | pasta | tcoffee
    run_tcs             = false
    run_bmge            = true
    bmge_entropy        = 0.5

    // ======== Part 1.4 — Phylogenetic inference ========
    tree_method         = 'iqtree'              // iqtree | raxml-ng | fasttree
    model_selection     = 'modelfinder'         // modelfinder | modeltest-ng | fixed
    substitution_model  = null                  // used only when model_selection = fixed
    bootstrap           = 5000
    outgroups           = null
    run_epang           = false

    // ========= Part 1.5 — Species delimitation =========
    run_delimitation    = true
    delimitation_method = 'mptp'                // mptp | bptp | asap
    mptp_mcmc           = 1000000

    // ==== Part 1.6 — Population structure & phylogeography ====
    run_phylogeography  = true
    diff_stat           = 'fst'                 // fst | jost_d | gst | all
    permutations        = 10000
    run_amova           = true
    cluster_method      = 'none'                // none | geneland | tess3r | samova
    run_basta           = false

    // ======= Part 2.7 — Environmental data retrieval =======
    run_environmental   = false
    env_layers          = 'bioclim,elevation,landcover'
    bioclim_source      = 'worldclim'           // worldclim | chelsa
    env_resolution      = 0.5                   // arc-minutes
    future_climate      = false

    // ===== Part 2.8 — Niche / distribution modelling =====
    run_sdm             = false
    sdm_algorithm       = 'maxent'              // maxent | randomforest | glm
    predictor_reduction = 'vif'                 // none | vif | pca
    background_points   = 10000

    // ===== Part 2.9 — Landscape genetics (IBD vs IBE) =====
    run_landscape_genetics = false
    lg_method              = 'mmrr'             // partial_mantel | mmrr | gdm | rda | all
    lg_permutations        = 10000

    // ================= Generic / behaviour =================
    publish_dir_mode    = 'copy'
    help                = false
    version             = false
    skip_validation     = false
    validationSchemaIgnoreParams = ''

    // ================= Max resource ceilings =================
    max_cpus            = 16
    max_memory          = '128.GB'
    max_time            = '240.h'
}

// ---- nf-schema plugin (provides --help, validation) ----
plugins {
    id 'nf-schema@2.1.1'
}

validation {
    help {
        enabled     = true
        command     = "nextflow run kibet-gilbert/phylogeoflow --target_taxon Ceratitis --outdir results -profile docker"
        beforeText  = """
-------------------------------------------------------
  phylogeoflow v0.1.0
  phylo + phylogeographic meta-analysis for any taxon
-------------------------------------------------------
"""
        afterText   = "\nDocs: https://github.com/kibet-gilbert/phylogeoflow\n"
    }
    lenientMode = true
}

// ---- default publishing behaviour for all processes ----
// (per-process resource allocation lives in conf/base.config, included below)
process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':').last().toLowerCase()}" },
        mode: params.publish_dir_mode
    ]
}

// ---- default resource allocation (CPU / memory / time per process class) ----
includeConfig 'conf/base.config'

// ---- execution profiles ----
profiles {
    debug {
        dumpHashes             = true
        process.beforeScript   = 'echo $HOSTNAME'
        cleanup                = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        docker.enabled         = false
    }
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    slurm {
        process.executor       = 'slurm'
    }
    test      { includeConfig 'conf/test.config'      }
    test_stub { includeConfig 'conf/test_stub.config' }
}

// ---- secrets used by processes (declared for documentation) ----
// nextflow secrets set BOLD_API_KEY  <key>
// nextflow secrets set GBIF_USER     <user>
// nextflow secrets set GBIF_PWD      <pwd>
// nextflow secrets set GBIF_EMAIL    <email>

// ---- point Nextflow at the bin/ scripts ----
// (Nextflow auto-adds ./bin to PATH for process scripts)

// ---- manifest ----
manifest {
    name            = 'kibet-gilbert/phylogeoflow'
    author          = 'Gilbert Kibet-Rono'
    homePage        = 'https://github.com/kibet-gilbert/phylogeoflow'
    description     = 'Phylogenetic & phylogeographic meta-analysis pipeline for arbitrary target taxa (BOLD/GenBank/GBIF + environment).'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '0.1.0'
    license         = 'MIT'
}

// ---- reporting ----
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html"   }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt"     }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html"      }

// ---- resource ceiling helper ----
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
